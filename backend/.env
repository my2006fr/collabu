# ─────────────────────────────────────────────
#  CollabU Backend — Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# Flask secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=b6b021acc5ac63897e3c90e7b83f1d8817c15f84001947edce62373239db881f
JWT_SECRET_KEY=42b5f5b7efbe8cc223494f2f6effe69159655e9e4f9f781aff4b89f5bcfde283

# Encryption key for GitHub PATs stored in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=Ma2BfBAwTKHFCGYf_FcE7My1JE3KAPSsKttwVscYT_M=

# University email domain (only emails ending in this domain can register)
ALLOWED_DOMAIN=myiuc.com

# JWT token lifetime in days
JWT_EXPIRES_DAYS=7

# ── Database ───────────────────────────────────
# Local dev:   leave as sqlite (default)
# Production:  set to your PostgreSQL URL from Render
# DATABASE_URL=sqlite:///student_collab.db
DATABASE_URL=postgresql://neondb_owner:npg_wfLiaCZt8n2Y@ep-late-bird-a1cz4bpk.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── CORS ───────────────────────────────────────
# Local dev:   http://localhost:5173
# Production:  your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://collabu.vercel.app

# ── File uploads ───────────────────────────────
UPLOAD_FOLDER=uploads
# Max upload size in MB
MAX_UPLOAD_MB=50

# ── GitHub OAuth (optional — for OAuth login flow) ─
# Create at: https://github.com/settings/developers > OAuth Apps
GITHUB_CLIENT_ID=Ov23liD4Aq0Z8APNbF0S
GITHUB_CLIENT_SECRET=5e4cc2c8fabf57512dd75f02d096a766c49dad3c

# ── Environment flag ───────────────────────────
# Set to "production" on Render
FLASK_ENV=production

# ─────────────────────────────────────────────
#  CollabU Frontend — Environment Variables
#  Copy to .env.local for local dev
#  Set these in Vercel dashboard for production
# ─────────────────────────────────────────────

# Backend URL
# Local dev:   leave empty (Vite proxy handles /api and /uploads)
# Production:  your Render backend URL e.g. https://collabu-backend.onrender.com
VITE_API_URL=

# WebSocket URL (same as API URL, without trailing slash)
# Local dev:   http://localhost:5000
# Production:  your Render backend URL
VITE_SOCKET_URL=http://localhost:5000
